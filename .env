# Smarty US Autocomplete Pro — powers the address search on /service-book.
#
# This is an EMBEDDED (website) key. It is intentionally public: it ships in the
# client bundle and is protected by a hostname allowlist configured in the Smarty
# dashboard (your production domain + localhost), not by secrecy. Committing it
# here is safe and lets every clone/build work without extra setup.
#
# To rotate: replace the value below and update the allowlist in the Smarty
# dashboard. Personal/local overrides can go in .env.local (gitignored).
NEXT_PUBLIC_SMARTY_KEY=281301570504039794

# Optional — only if your account must route to a specific license.
# NEXT_PUBLIC_SMARTY_LICENSE=us-autocomplete-pro-cloud
